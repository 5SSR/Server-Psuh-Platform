generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ========== 枚举定义 ==========

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
}

enum ProductCategory {
  DEDICATED
  VPS
  CLOUD
  NAT
  LINE
}

enum ProductStatus {
  DRAFT
  PENDING
  ONLINE
  OFFLINE
}

enum ProductImageType {
  BILL
  PANEL
  BENCHMARK
  OTHER
}

enum ProductAuditStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DeliveryType {
  FULL_ACCOUNT
  PANEL_TRANSFER
  SUB_ACCOUNT
  EMAIL_CHANGE
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID_WAITING_DELIVERY
  VERIFYING
  BUYER_CHECKING
  COMPLETED_PENDING_SETTLEMENT
  COMPLETED
  REFUNDING
  DISPUTING
  CANCELED
}

enum PayStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
  CLOSED
}

enum PayChannel {
  BALANCE
  ALIPAY
  WECHAT
  USDT
  MANUAL
}

enum VerifyResult {
  PASS
  FAIL
  NEED_MORE
}

enum SettlementStatus {
  PENDING
  RELEASED
  REJECTED
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DisputeStatus {
  OPEN
  PROCESSING
  RESOLVED
  REJECTED
}

enum DisputeInitiator {
  BUYER
  SELLER
  ADMIN
}

enum WalletLedgerType {
  PAY
  ESCROW_FREEZE
  ESCROW_RELEASE
  REFUND
  WITHDRAW
  FEE
  ADJUST
}

enum NoticeChannel {
  SITE
  EMAIL
  TG
  SMS
  WECHAT_TEMPLATE
}

enum NoticeStatus {
  PENDING
  SENT
  FAILED
}

enum AuthCodeScene {
  VERIFY_EMAIL
  RESET_PASSWORD
}

enum ActorType {
  USER
  ADMIN
  SYSTEM
}

enum SellerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WantedStatus {
  OPEN
  CLOSED
}

enum WantedOfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum BargainStatus {
  WAIT_SELLER
  WAIT_BUYER
  ACCEPTED
  REJECTED
  CANCELED
}

enum BargainActor {
  BUYER
  SELLER
}

enum ConsignmentApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum ReconcileTaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum ReconcileDiffType {
  MISSING_LOCAL
  MISSING_REMOTE
  AMOUNT_MISMATCH
  STATUS_MISMATCH
  DUPLICATE_REMOTE
}

enum ReconcileItemStatus {
  OPEN
  RESOLVED
  IGNORED
}

enum RiskScene {
  LOGIN
  CREATE_ORDER
  PAYMENT_CALLBACK
  WITHDRAW
}

enum RiskAction {
  ALLOW
  REVIEW
  LIMIT
  ALERT
  BLOCK
}

enum FeePayer {
  BUYER
  SELLER
  SHARED
}

enum FeeConfigScene {
  ORDER
  WITHDRAW
}

enum FeeConfigMode {
  FIXED
  RATE
  TIER
}

// ========== 用户与认证 ==========

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  passwordHash String
  nickname     String?
  avatar       String?
  role         UserRole    @default(BUYER)
  status       UserStatus  @default(ACTIVE)
  emailVerifiedAt DateTime?
  mfaEnabled   Boolean     @default(false)
  mfaSecret    String?
  lastLoginAt  DateTime?
  lastLoginIp  String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  kyc           UserKyc?
  sellerApplication SellerApplication?
  sellerProfile SellerProfile?
  wallet        Wallet?
  products      Product[]         @relation("SellerProducts")
  orders        Order[]           @relation("BuyerOrders")
  notices       Notice[]
  orderLogs     OrderLog[]        @relation("UserOrderLogs")
  disputes      Dispute[]         @relation("UserDisputes")
  evidences     DisputeEvidence[]
  sellerOrders  Order[]           @relation("SellerOrders")
  loginLogs     UserLoginLog[]
  favorites     Favorite[]
  browsingHistory BrowsingHistory[]
  priceAlerts   PriceAlert[]
  wantedRequests WantedRequest[] @relation("BuyerWantedRequests")
  wantedOffers   WantedOffer[]   @relation("SellerWantedOffers")
  buyerBargains  Bargain[]       @relation("BuyerBargains")
  sellerBargains Bargain[]       @relation("SellerBargains")
  consignmentApplications ConsignmentApplication[] @relation("SellerConsignments")
  reviewedConsignments ConsignmentApplication[]    @relation("ConsignmentReviewer")
  storeProfile StoreProfile?
  buyerReviews OrderReview[]                       @relation("BuyerReviews")
  sellerReviews OrderReview[]                      @relation("SellerReviews")
  openApiKeys OpenApiKey[]
}

model AuthCode {
  id        String        @id @default(uuid())
  email     String
  scene     AuthCodeScene
  codeHash  String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  @@index([email, scene, createdAt])
  @@index([expiresAt])
}

model UserLoginLog {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  email     String
  ip        String?
  userAgent String?
  success   Boolean  @default(true)
  reason    String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([email, createdAt])
}

model UserKyc {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  realName  String
  idNumber  String
  docImages String?
  status    String   @default("pending") // pending/approved/rejected
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SellerApplication {
  id        String                  @id @default(uuid())
  user      User                    @relation(fields: [userId], references: [id])
  userId    String                  @unique
  status    SellerApplicationStatus @default(PENDING)
  reason    String?
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([status, createdAt])
}

model SellerProfile {
  id                  String  @id @default(uuid())
  user                User    @relation(fields: [userId], references: [id])
  userId              String  @unique
  level               Int     @default(1)
  tradeCount          Int     @default(0)
  disputeRate         Float   @default(0)
  avgDeliveryMinutes  Int     @default(0)
  positiveRate        Float   @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model StoreProfile {
  id              String   @id @default(uuid())
  user            User     @relation(fields: [userId], references: [id])
  userId          String   @unique
  name            String
  slug            String   @unique
  logo            String?
  banner          String?
  intro           String?
  notice          String?
  verifiedBadge   Boolean  @default(false)
  responseMinutes Int      @default(30)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([name])
}

model OpenApiKey {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  name      String
  keyPrefix String
  keyHash   String   @unique
  scope     String?
  status    String   @default("ACTIVE")
  lastUsedAt DateTime?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  callLogs  OpenApiCallLog[]
  nonces    OpenApiNonce[]

  @@index([userId, status])
  @@index([status, expiresAt])
}

model OpenApiCallLog {
  id           String      @id @default(uuid())
  openApiKey   OpenApiKey? @relation(fields: [openApiKeyId], references: [id])
  openApiKeyId String?
  userId       String?
  keyPrefix    String?
  requestPath  String
  requestMethod String
  nonce        String?
  signatureMode String?
  ip           String?
  statusCode   Int
  success      Boolean     @default(false)
  errorCode    String?
  errorMessage String?
  durationMs   Int         @default(0)
  createdAt    DateTime    @default(now())

  @@index([openApiKeyId, createdAt])
  @@index([userId, createdAt])
  @@index([keyPrefix, createdAt])
  @@index([requestPath, createdAt])
  @@index([success, createdAt])
}

model OpenApiNonce {
  id           String     @id @default(uuid())
  openApiKey   OpenApiKey @relation(fields: [openApiKeyId], references: [id])
  openApiKeyId String
  nonce        String
  createdAt    DateTime   @default(now())

  @@unique([openApiKeyId, nonce])
  @@index([createdAt])
}

// ========== 钱包 ==========

model Wallet {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String   @unique
  balance   Decimal  @default(0) @db.Decimal(16, 2)
  frozen    Decimal  @default(0) @db.Decimal(16, 2)
  currency  String   @default("CNY")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledgers     WalletLedger[]
  withdrawals Withdrawal[]
}

model WalletLedger {
  id        String           @id @default(uuid())
  wallet    Wallet           @relation(fields: [walletId], references: [id])
  walletId  String
  type      WalletLedgerType
  amount    Decimal          @db.Decimal(16, 2)
  refType   String?
  refId     String?
  memo      String?
  createdAt DateTime         @default(now())

  @@index([walletId, createdAt])
}

model Withdrawal {
  id           String   @id @default(uuid())
  wallet       Wallet   @relation(fields: [walletId], references: [id])
  walletId     String
  amount       Decimal  @db.Decimal(16, 2)
  fee          Decimal  @default(0) @db.Decimal(16, 2)
  channel      String
  accountInfo  String
  status       String   @default("pending") // pending/approved/paid/rejected
  processedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([walletId, status])
}

model FeeConfig {
  id        String         @id @default(uuid())
  scene     FeeConfigScene @unique
  mode      FeeConfigMode  @default(RATE)
  payer     FeePayer?
  fixedFee  Decimal?       @db.Decimal(16, 2)
  rate      Decimal?       @db.Decimal(8, 4)
  minFee    Decimal?       @db.Decimal(16, 2)
  tiers     Json?
  remark    String?
  updatedBy String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

// ========== 商品 ==========

model Product {
  id                String          @id @default(uuid())
  seller            User            @relation("SellerProducts", fields: [sellerId], references: [id])
  sellerId          String
  code              String          @unique
  title             String
  category          ProductCategory
  region            String
  datacenter        String?
  lineType          String?
  providerName      String?
  providerUrl       String?
  cpuModel          String?
  cpuCores          Int?
  memoryGb          Int?
  diskGb            Int?
  diskType          String?
  bandwidthMbps     Int?
  trafficLimit      Int?
  ipCount           Int?
  ddos              Int?
  purchasePrice     Decimal?        @db.Decimal(16, 2)
  salePrice         Decimal         @db.Decimal(16, 2)
  renewPrice        Decimal?        @db.Decimal(16, 2)
  expireAt          DateTime?
  negotiable        Boolean         @default(false)
  consignment       Boolean         @default(false)
  isPremium         Boolean         @default(false)
  premiumRate       Decimal?        @db.Decimal(6, 4)
  deliveryType      DeliveryType
  feePayer          FeePayer        @default(SELLER)
  canChangeEmail    Boolean         @default(false)
  canChangeRealname Boolean         @default(false)
  canTest           Boolean         @default(false)
  canTransfer       Boolean         @default(false)
  riskLevel         RiskLevel       @default(MEDIUM)
  abuseHistory      Boolean         @default(false)
  accountRecallRisk Boolean         @default(false)
  riskTags          Json?
  description       String?
  status            ProductStatus   @default(DRAFT)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  images   ProductImage[]
  audits   ProductAudit[]
  orders   Order[]
  favorites Favorite[]
  browsingHistory BrowsingHistory[]
  priceAlerts PriceAlert[]
  wantedOffers WantedOffer[]
  bargains Bargain[]
  consignmentApplications ConsignmentApplication[]

  @@index([sellerId, status])
  @@index([category, status])
  @@index([region, lineType])
}

model ConsignmentApplication {
  id          String                       @id @default(uuid())
  product     Product                      @relation(fields: [productId], references: [id])
  productId   String
  seller      User                         @relation("SellerConsignments", fields: [sellerId], references: [id])
  sellerId    String
  status      ConsignmentApplicationStatus @default(PENDING)
  sellerNote  String?
  adminRemark String?
  reviewedBy  String?
  reviewer    User?                        @relation("ConsignmentReviewer", fields: [reviewedBy], references: [id])
  reviewedAt  DateTime?
  createdAt   DateTime                     @default(now())
  updatedAt   DateTime                     @updatedAt

  @@index([sellerId, status])
  @@index([productId, status])
  @@index([status, createdAt])
}

model ProductImage {
  id        String           @id @default(uuid())
  product   Product          @relation(fields: [productId], references: [id])
  productId String
  type      ProductImageType
  url       String
  createdAt DateTime         @default(now())
}

model ProductAudit {
  id        String             @id @default(uuid())
  product   Product            @relation(fields: [productId], references: [id])
  productId String
  adminId   String?
  status    ProductAuditStatus @default(PENDING)
  reason    String?
  snapshot  Json?
  createdAt DateTime           @default(now())

  @@index([productId, status])
}

model WantedRequest {
  id             String          @id @default(uuid())
  buyer          User            @relation("BuyerWantedRequests", fields: [buyerId], references: [id])
  buyerId        String
  title          String
  category       ProductCategory?
  region         String
  lineType       String?
  cpuCores       Int?
  memoryGb       Int?
  diskGb         Int?
  bandwidthMbps  Int?
  budgetMin      Decimal?        @db.Decimal(16, 2)
  budgetMax      Decimal?        @db.Decimal(16, 2)
  acceptPremium  Boolean         @default(false)
  description    String?
  expireAt       DateTime?
  status         WantedStatus    @default(OPEN)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  offers WantedOffer[]

  @@index([buyerId, status])
  @@index([status, createdAt])
  @@index([category, region])
}

model WantedOffer {
  id          String            @id @default(uuid())
  wanted      WantedRequest     @relation(fields: [wantedId], references: [id])
  wantedId    String
  seller      User              @relation("SellerWantedOffers", fields: [sellerId], references: [id])
  sellerId    String
  product     Product?          @relation(fields: [productId], references: [id])
  productId   String?
  offerPrice  Decimal           @db.Decimal(16, 2)
  message     String?
  status      WantedOfferStatus @default(PENDING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([wantedId, sellerId])
  @@index([sellerId, status])
  @@index([wantedId, status])
}

model Bargain {
  id              String        @id @default(uuid())
  product         Product       @relation(fields: [productId], references: [id])
  productId       String
  buyer           User          @relation("BuyerBargains", fields: [buyerId], references: [id])
  buyerId         String
  seller          User          @relation("SellerBargains", fields: [sellerId], references: [id])
  sellerId        String
  status          BargainStatus @default(WAIT_SELLER)
  lastActor       BargainActor
  round           Int           @default(1)
  currentPrice    Decimal       @db.Decimal(16, 2)
  buyerLastPrice  Decimal?      @db.Decimal(16, 2)
  sellerLastPrice Decimal?      @db.Decimal(16, 2)
  remark          String?
  expireAt        DateTime?
  order           Order?        @relation(fields: [orderId], references: [id])
  orderId         String?       @unique
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  logs BargainLog[]

  @@index([productId, status])
  @@index([buyerId, status])
  @@index([sellerId, status])
}

model BargainLog {
  id        String      @id @default(uuid())
  bargain   Bargain     @relation(fields: [bargainId], references: [id])
  bargainId String
  action    String
  actor     BargainActor
  actorId   String?
  price     Decimal?    @db.Decimal(16, 2)
  remark    String?
  createdAt DateTime    @default(now())

  @@index([bargainId, createdAt])
}

// ========== 订单与支付 ==========

model Order {
  id               String      @id @default(uuid())
  buyer            User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  buyerId          String
  seller           User        @relation("SellerOrders", fields: [sellerId], references: [id])
  sellerId         String
  product          Product     @relation(fields: [productId], references: [id])
  productId        String
  price            Decimal     @db.Decimal(16, 2)
  fee              Decimal     @default(0) @db.Decimal(16, 2)
  feePayer         FeePayer    @default(SELLER)
  payChannel       PayChannel  @default(BALANCE)
  payStatus        PayStatus   @default(UNPAID)
  escrowAmount     Decimal     @db.Decimal(16, 2)
  status           OrderStatus @default(PENDING_PAYMENT)
  expiresAt        DateTime?
  autoConfirmAt    DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  payment         Payment?
  deliveryRecords DeliveryRecord[]
  verifyRecords   VerifyRecord[]
  settlement      Settlement?
  refund          Refund?
  dispute         Dispute?
  logs            OrderLog[]
  bargain         Bargain?
  review          OrderReview?

  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([productId])
}

model OrderReview {
  id        String   @id @default(uuid())
  order     Order    @relation(fields: [orderId], references: [id])
  orderId   String   @unique
  buyer     User     @relation("BuyerReviews", fields: [buyerId], references: [id])
  buyerId   String
  seller    User     @relation("SellerReviews", fields: [sellerId], references: [id])
  sellerId  String
  rating    Int
  content   String?
  tags      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sellerId, createdAt])
  @@index([buyerId, createdAt])
}

model Payment {
  id            String    @id @default(uuid())
  order         Order     @relation(fields: [orderId], references: [id])
  orderId       String    @unique
  channel       PayChannel
  tradeNo       String?
  channelOrderId String?
  thirdTradeNo  String?
  amount        Decimal   @db.Decimal(16, 2)
  paidAmount    Decimal?  @db.Decimal(16, 2)
  currency      String    @default("CNY")
  payStatus     PayStatus @default(UNPAID)
  paidAt        DateTime?
  notifyAt      DateTime?
  closeAt       DateTime?
  failReason    String?
  notifyPayload Json?
  notifyRaw     Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  events       PaymentEvent[]

  @@index([tradeNo])
  @@index([thirdTradeNo])
  @@index([channelOrderId])
  @@index([payStatus, createdAt])
}

model PaymentEvent {
  id        String   @id @default(uuid())
  payment   Payment  @relation(fields: [paymentId], references: [id])
  paymentId String
  eventType String
  source    String?
  payload   Json?
  createdAt DateTime @default(now())

  @@index([paymentId, createdAt])
  @@index([eventType, createdAt])
}

model ReconcileTask {
  id         String              @id @default(uuid())
  channel    PayChannel
  bizDate    DateTime
  status     ReconcileTaskStatus @default(PENDING)
  startedAt  DateTime?
  finishedAt DateTime?
  summary    Json?
  error      String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  items ReconcileItem[]

  @@unique([channel, bizDate])
  @@index([status, createdAt])
}

model ReconcileItem {
  id           String              @id @default(uuid())
  task         ReconcileTask       @relation(fields: [taskId], references: [id])
  taskId       String
  orderId      String?
  tradeNo      String?
  thirdTradeNo String?
  diffType     ReconcileDiffType
  status       ReconcileItemStatus @default(OPEN)
  localAmount  Decimal?            @db.Decimal(16, 2)
  remoteAmount Decimal?            @db.Decimal(16, 2)
  localStatus  String?
  remoteStatus String?
  note         String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([taskId, status])
  @@index([diffType, createdAt])
}

model RiskRule {
  id          String     @id @default(uuid())
  code        String     @unique
  name        String
  scene       RiskScene
  enabled     Boolean    @default(true)
  priority    Int        @default(100)
  action      RiskAction @default(ALERT)
  condition   Json
  reason      String?
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([scene, enabled, priority])
}

model RiskHit {
  id             String     @id @default(uuid())
  scene          RiskScene
  action         RiskAction
  matchedRuleIds Json?
  decisionReason String?
  userId         String?
  ip             String?
  input          Json?
  createdAt      DateTime   @default(now())

  @@index([scene, createdAt])
  @@index([userId, createdAt])
}

model RiskEntityList {
  id          String   @id @default(uuid())
  listType    String   // BLACKLIST / WHITELIST
  entityType  String   // USER_ID / IP / EMAIL / ACCOUNT
  entityValue String
  enabled     Boolean  @default(true)
  reason      String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@unique([listType, entityType, entityValue])
  @@index([entityType, entityValue, enabled])
}

model DeliveryRecord {
  id                     String   @id @default(uuid())
  order                  Order    @relation(fields: [orderId], references: [id])
  orderId                String
  providerAccount        String?
  panelUrl               String?
  loginInfo              String?
  changeEmailPossible    Boolean  @default(false)
  changeRealnamePossible Boolean  @default(false)
  remark                 String?
  createdAt              DateTime @default(now())
}

model VerifyRecord {
  id        String       @id @default(uuid())
  order     Order        @relation(fields: [orderId], references: [id])
  orderId   String
  verifierId String?
  result    VerifyResult
  checklist Json?
  createdAt DateTime     @default(now())
}

model Settlement {
  id         String            @id @default(uuid())
  order      Order             @relation(fields: [orderId], references: [id])
  orderId    String            @unique
  sellerId   String
  amount     Decimal           @db.Decimal(16, 2)
  fee        Decimal           @default(0) @db.Decimal(16, 2)
  releasedAt DateTime?
  status     SettlementStatus  @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
}

model Refund {
  id          String       @id @default(uuid())
  order       Order        @relation(fields: [orderId], references: [id])
  orderId     String       @unique
  applicantId String
  reason      String
  amount      Decimal      @db.Decimal(16, 2)
  status      RefundStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Dispute {
  id          String          @id @default(uuid())
  order       Order           @relation(fields: [orderId], references: [id])
  orderId     String          @unique
  initiator   DisputeInitiator
  initiatorUser   User?       @relation("UserDisputes", fields: [initiatorUserId], references: [id])
  initiatorUserId String?
  status      DisputeStatus   @default(OPEN)
  result      String?
  resolution  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  evidences DisputeEvidence[]
}

model DisputeEvidence {
  id        String   @id @default(uuid())
  dispute   Dispute  @relation(fields: [disputeId], references: [id])
  disputeId String
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  url       String
  note      String?
  createdAt DateTime @default(now())

  @@index([disputeId])
}

model OrderLog {
  id        String    @id @default(uuid())
  order     Order     @relation(fields: [orderId], references: [id])
  orderId   String
  action    String
  actorType ActorType
  actorId   String?
  actorUser User?     @relation("UserOrderLogs", fields: [actorId], references: [id])
  remark    String?
  createdAt DateTime  @default(now())

  @@index([orderId])
}

// ========== 通知 ==========

model Notice {
  id          String        @id @default(uuid())
  user        User?         @relation(fields: [userId], references: [id])
  userId      String?
  type        String
  channel     NoticeChannel @default(SITE)
  templateId  String?
  payload     Json?
  status      NoticeStatus  @default(PENDING)
  sentAt      DateTime?
  createdAt   DateTime      @default(now())
}

// ========== 内容运营 ==========

model Banner {
  id        String   @id @default(uuid())
  title     String
  subtitle  String?
  imageUrl  String?
  linkUrl   String?
  badge     String?
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, position])
}

model Faq {
  id        String   @id @default(uuid())
  category  String?  @default("通用")
  question  String
  answer    String
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, position])
}

model HelpArticle {
  id        String   @id @default(uuid())
  category  String?  @default("帮助中心")
  title     String
  content   String
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, position])
}

model MarketTag {
  id        String   @id @default(uuid())
  name      String
  type      String   @default("GENERAL")
  color     String?
  position  Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, isActive, position])
}

// ========== 管理员审计日志 ==========

model AdminLog {
  id        String   @id @default(uuid())
  adminId   String
  action    String
  resource  String
  resourceId String?
  detail    Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([resource, createdAt])
}

// ========== 通知模板 ==========

model NoticeTemplate {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  channel     NoticeChannel @default(SITE)
  subject     String?
  bodyTemplate String  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ========== 收藏 / 浏览历史 / 价格提醒 ==========

model Favorite {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId, createdAt])
}

model BrowsingHistory {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  product   Product  @relation(fields: [productId], references: [id])
  productId String
  viewedAt  DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId, viewedAt])
  @@index([productId])
}

model PriceAlert {
  id          String   @id @default(uuid())
  user        User     @relation(fields: [userId], references: [id])
  userId      String
  product     Product  @relation(fields: [productId], references: [id])
  productId   String
  targetPrice Decimal  @db.Decimal(16, 2)
  triggered   Boolean  @default(false)
  triggeredAt DateTime?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([productId, triggered])
}
